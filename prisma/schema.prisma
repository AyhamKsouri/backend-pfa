// ============================================================
// Prisma Schema – AI Project Management System
// ============================================================

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  ADMIN
  MEMBER
}

enum Methodology {
  AGILE
  WATERFALL
  KANBAN
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum Complexity {
  LOW
  MEDIUM
  HIGH
}

enum ExperienceLevel {
  JUNIOR
  MID
  SENIOR
}

enum NotificationType {
  MENTION
  TASK_ASSIGNED
  STATUS_CHANGED
  COMMENT_ADDED
}

// ============================================================
// USER
// ============================================================

model User {
  id             Int      @id @default(autoincrement())
  email          String   @unique
  username       String   @unique
  passwordHash   String
  role           Role     @default(MEMBER)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  ownedProjects      Project[]         @relation("ProjectOwner")
  projectMemberships ProjectMember[]
  assignedTasks      Task[]            @relation("TaskAssignee")
  comments           Comment[]
  mentions           Mention[]         @relation("MentionedUser")
  notifications      Notification[]    @relation("NotificationRecipient")

  @@index([email])
  @@index([role])
}

// ============================================================
// PROJECT
// ============================================================

model Project {
  id               Int           @id @default(autoincrement())
  name             String
  description      String?
  methodology      Methodology
  status           ProjectStatus @default(ACTIVE)
  complexity       Complexity    @default(MEDIUM)
  durationMonths   Int
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Owner (Admin who created it)
  ownerId          Int
  owner            User          @relation("ProjectOwner", fields: [ownerId], references: [id])

  // Relations
  members          ProjectMember[]
  tasks            Task[]
  sprints          Sprint[]

  @@index([ownerId])
  @@index([status])
  @@index([methodology])
}

enum ProjectMemberRole {
  ADMIN
  MEMBER
}

// ============================================================
// PROJECT MEMBER  (join table: User ↔ Project, with skills)
// ============================================================

model ProjectMember {
  id                 Int             @id @default(autoincrement())
  weeklyAvailability Int             @default(40) // hours per week
  experienceLevel    ExperienceLevel @default(MID)
  role               ProjectMemberRole @default(MEMBER)
  joinedAt           DateTime        @default(now())

  userId             Int
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId          Int
  project            Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Skills for this member in this project
  skills             Skill[]

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
  @@index([projectId, role])
}

// ============================================================
// SKILL  (belongs to a ProjectMember)
// ============================================================

model Skill {
  id       Int    @id @default(autoincrement())
  name     String // e.g. "React", "Node.js", "Python"

  memberId Int
  member   ProjectMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([name])
  @@index([memberId, name])
}

// ============================================================
// SPRINT  (Agile mode only)
// ============================================================

model Sprint {
  id          Int      @id @default(autoincrement())
  name        String   // e.g. "Sprint 1"
  goal        String?
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime @default(now())

  projectId   Int
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  tasks       Task[]

  @@index([projectId])
  @@index([startDate, endDate])
}

// ============================================================
// TASK
// ============================================================

model Task {
  id              Int        @id @default(autoincrement())
  title           String
  description     String?
  status          TaskStatus @default(TODO)
  progressPercent Int        @default(0) // 0-100
  startDate       DateTime?
  dueDate         DateTime?
  estimatedHours  Int?
  aiGenerated     Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Foreign keys
  projectId       Int
  project         Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assignedToId    Int?
  assignedTo      User?      @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  sprintId        Int?
  sprint          Sprint?    @relation(fields: [sprintId], references: [id], onDelete: SetNull)

  // Self-referential dependencies (task depends on other tasks)
  dependencies    TaskDependency[] @relation("DependentTask")
  dependents      TaskDependency[] @relation("DependencyTask")

  // Relations
  comments        Comment[]
  statusHistory   TaskStatusHistory[]

  @@index([projectId])
  @@index([assignedToId])
  @@index([status])
  @@index([sprintId])
  @@index([dueDate])
  @@index([projectId, status])         // composite – used by GET /tasks?projectId=&status=
  @@index([assignedToId, status])      // composite – used by member dashboard
}

// ============================================================
// TASK DEPENDENCY  (self-join: Task depends on Task)
// ============================================================

model TaskDependency {
  id             Int  @id @default(autoincrement())

  // The task that has a prerequisite
  dependentId    Int
  dependent      Task @relation("DependentTask", fields: [dependentId], references: [id], onDelete: Cascade)

  // The prerequisite task that must finish first
  dependencyId   Int
  dependency     Task @relation("DependencyTask", fields: [dependencyId], references: [id], onDelete: Cascade)

  @@unique([dependentId, dependencyId])
  @@index([dependentId])
  @@index([dependencyId])
}

// ============================================================
// TASK STATUS HISTORY  (for burndown chart – task B15)
// ============================================================

model TaskStatusHistory {
  id         Int        @id @default(autoincrement())
  oldStatus  TaskStatus
  newStatus  TaskStatus
  changedAt  DateTime   @default(now())

  taskId     Int
  task       Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([changedAt])
}

// ============================================================
// COMMENT
// ============================================================

model Comment {
  id        Int      @id @default(autoincrement())
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taskId    Int
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  authorId  Int
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // Parsed @mentions
  mentions  Mention[]

  @@index([taskId])
  @@index([authorId])
  @@index([taskId, createdAt])   // composite – chronological comments per task
}

// ============================================================
// MENTION  (parsed from comment text, e.g. "@alice")
// ============================================================

model Mention {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())

  commentId   Int
  comment     Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  // The user who was mentioned
  mentionedId Int
  mentioned   User     @relation("MentionedUser", fields: [mentionedId], references: [id], onDelete: Cascade)

  // Creating a mention also spawns a Notification (see below)
  notification Notification?

  @@unique([commentId, mentionedId])
  @@index([commentId])
  @@index([mentionedId])
}

// ============================================================
// NOTIFICATION
// ============================================================

model Notification {
  id        Int              @id @default(autoincrement())
  type      NotificationType
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  // Recipient
  recipientId Int
  recipient   User  @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  // Optional link back to the mention that triggered this
  mentionId   Int?     @unique
  mention     Mention? @relation(fields: [mentionId], references: [id], onDelete: SetNull)

  @@index([recipientId])
  @@index([recipientId, isRead])   // composite – unread notifications per user
  @@index([recipientId, createdAt])
  @@index([createdAt])
}
